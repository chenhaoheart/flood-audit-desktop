{
  "name": "flood-audit-desktop",
  "version": "1.0.0",
  "description": "山洪灾害数据审核汇集系统 - Electron桌面应用",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "nodemon --exec electron .",
    "dev:renderer": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "package": "electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^9.0.0",
    "spatialite": "^1.0.0",
    "json-rules-engine": "^7.0.0",
    "mapbox-gl": "^2.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "antd": "^5.12.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "vite": "^5.0.0",
    "vite-plugin-react": "^4.0.0",
    "electron-builder": "^24.0.0",
    "concurrently": "^8.0.0",
    "nodemon": "^3.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.floodaudit.desktop",
    "productName": "山洪审核桌面应用",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}